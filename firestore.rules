rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function room(roomId) {
      return get(/databases/$(database)/documents/chat_rooms/$(roomId));
    }

    function isExistingRoomParticipant() {
      return signedIn()
        && resource.data.participants is list
        && request.auth.uid in resource.data.participants;
    }

    function isDirectRoomIdParticipant(roomId) {
      return signedIn()
        && resource.data.isGroup != true
        && roomId.matches('(^|_)' + request.auth.uid + '(_|$)');
    }

    function isParentRoomParticipant(roomId) {
      return signedIn()
        && room(roomId).data.participants is list
        && request.auth.uid in room(roomId).data.participants;
    }

    function isParentDirectRoomIdParticipant(roomId) {
      return signedIn()
        && room(roomId).data.isGroup != true
        && roomId.matches('(^|_)' + request.auth.uid + '(_|$)');
    }

    function roomAfter(roomId) {
      return getAfter(/databases/$(database)/documents/chat_rooms/$(roomId));
    }

    function isParentRoomParticipantAfter(roomId) {
      return signedIn()
        && roomAfter(roomId).data.participants is list
        && request.auth.uid in roomAfter(roomId).data.participants;
    }

    function isCallParticipant() {
      return signedIn()
        && resource.data.participants is list
        && request.auth.uid in resource.data.participants;
    }

    function isExistingCallParticipant(callId) {
      return signedIn()
        && get(/databases/$(database)/documents/calls/$(callId)).data.participants is list
        && request.auth.uid in get(/databases/$(database)/documents/calls/$(callId)).data.participants;
    }

    function isCreatingCallAsParticipant() {
      return signedIn()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.callerId == request.auth.uid;
    }

    function isCreatingDirectRoomAsParticipant() {
      return signedIn()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;
    }

    function isCreatingGroupRoomAsAdmin() {
      return signedIn()
        && request.resource.data.isGroup == true
        && request.resource.data.participants is list
        && request.resource.data.participants.size() >= 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.admins is list
        && request.resource.data.admins.size() == 1
        && request.auth.uid in request.resource.data.admins
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.name is string;
    }

    function keepsParticipantsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['participants']);
    }

    function keepsGroupAdminFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'admins',
        'createdBy',
        'name',
        'photoUrl',
        'isGroup'
      ]);
    }

    function isExistingGroupAdmin() {
      return signedIn()
        && resource.data.isGroup == true
        && resource.data.admins is list
        && request.auth.uid in resource.data.admins;
    }

    function isUpdatingCallMessage() {
      return resource.data.type == 'call'
        && request.resource.data.type == 'call'
        && resource.data.callId == request.resource.data.callId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'text',
          'callStatus',
          'callType',
          'callDurationSeconds',
          'deliveredTo',
          'readBy',
          'deletedFor',
          'reactions'
        ]);
    }

    function isUpdatingOwnTextMessage() {
      return resource.data.senderId == request.auth.uid
        && resource.data.type == 'text'
        && request.resource.data.type == resource.data.type
        && request.resource.data.senderId == resource.data.senderId
        && request.resource.data.get('deletedForEveryone', false) != true
        && request.resource.data.editedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'text',
          'editedAt'
        ]);
    }

    function isDeletingOwnMessageForEveryone() {
      return resource.data.senderId == request.auth.uid
        && request.resource.data.senderId == resource.data.senderId
        && request.resource.data.deletedForEveryone == true
        && request.resource.data.deletedForEveryoneAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'text',
          'imageUrl',
          'localImagePath',
          'videoUrl',
          'localVideoPath',
          'fileUrl',
          'localFilePath',
          'fileName',
          'fileSize',
          'fileExtension',
          'contactName',
          'contactPhone',
          'audioUrl',
          'localAudioPath',
          'audioDurationSeconds',
          'reactions',
          'deletedForEveryone',
          'deletedForEveryoneAt'
        ]);
    }

    function isVerifiedOwnEmailUpdate() {
      return request.resource.data.email == request.auth.token.email
        && resource.data.pendingEmail == request.auth.token.email;
    }

    match /users/{uid} {
      // Public read is kept for the current username-login flow.
      // Move public fields to a separate profile collection before tightening this.
      allow get, list: if true;

      allow create: if isOwner(uid)
        && request.resource.data.id == uid
        && request.resource.data.email == request.auth.token.email;

      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['id', 'email'])
        || isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasAny(['email'])
        && isVerifiedOwnEmailUpdate();

      allow delete: if false;

      match /friends/{friendUid} {
        allow read: if isOwner(uid);

        allow create: if request.resource.data.uid == friendUid
          && request.resource.data.createdAt == request.time
          && (
            isOwner(uid) ||
            (signedIn() && request.auth.uid == friendUid)
          );

        allow delete: if isOwner(uid);
        allow update: if false;
      }

      match /friend_requests/{requestId} {
        allow read: if isOwner(uid);

        allow create: if signedIn()
          && request.resource.data.toUid == uid
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.status == 'pending';

        allow delete: if signedIn()
          && (request.auth.uid == uid || request.auth.uid == resource.data.fromUid);

        allow update: if false;
      }

      match /outgoing_friend_requests/{requestId} {
        allow read: if isOwner(uid);

        allow create: if isOwner(uid)
          && request.resource.data.fromUid == uid
          && request.resource.data.status == 'pending';

        allow delete: if signedIn()
          && (request.auth.uid == uid || request.auth.uid == resource.data.toUid);

        allow update: if false;
      }
    }

    match /chat_rooms/{roomId} {
      allow get: if isExistingRoomParticipant()
        || isDirectRoomIdParticipant(roomId);

      allow list: if signedIn();

      allow create: if isCreatingDirectRoomAsParticipant()
        || isCreatingGroupRoomAsAdmin();

      allow update: if (isExistingRoomParticipant() || isDirectRoomIdParticipant(roomId))
        && (
          (keepsParticipantsUnchanged() && keepsGroupAdminFieldsUnchanged()) ||
          isExistingGroupAdmin()
        );

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isParentRoomParticipant(roomId)
          || isParentDirectRoomIdParticipant(roomId);

        allow create: if (
            isParentRoomParticipant(roomId) ||
            isParentDirectRoomIdParticipant(roomId) ||
            isParentRoomParticipantAfter(roomId)
          )
          && request.resource.data.senderId == request.auth.uid;

        allow update: if isParentRoomParticipant(roomId)
          && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'deliveredTo',
              'readBy',
              'deletedFor',
              'reactions'
            ]) ||
            isUpdatingOwnTextMessage() ||
            isDeletingOwnMessageForEveryone() ||
            isUpdatingCallMessage()
          );

        allow delete: if false;
      }
    }

    match /calls/{callId} {
      allow get: if isCallParticipant();

      allow list: if signedIn();

      allow create: if isCreatingCallAsParticipant();

      allow update: if isCallParticipant()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['participants', 'callerId', 'calleeId']);

      allow delete: if false;

      match /caller_candidates/{candidateId} {
        allow read: if isExistingCallParticipant(callId);
        allow create: if isExistingCallParticipant(callId);
        allow update, delete: if false;
      }

      match /callee_candidates/{candidateId} {
        allow read: if isExistingCallParticipant(callId);
        allow create: if isExistingCallParticipant(callId);
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
